{
  "id": "demo_direct_gdb_file_nonpie_cwd_dotfile",
  "challenge_dir": "challenge/bench_local_nonpie",
  "binary": "chall",
  "max_loops": 1,
  "start_no_codex": true,
  "allow_codex_missing": true,
  "clear_cached_artifacts": true,
  "cwd": "challenge/bench_local_nonpie",
  "run_session_args": ["--policy", "policy/agent_l0_l2.yaml", "--no-fast"],
  "env": {
    "DIRGE_PREFER_LOCAL_GDB_ON_CODEX_MISSING": "1",
    "DIRGE_GDB_MCP_CMD": "python3 -u scripts/fake_gdb_mcp.py",
    "DIRGE_GDB_MCP_CWD": ".",
    "DIRGE_GDB_DIRECT_STDIN_FILE": "./cyclic88.txt",
    "DIRGE_FAKE_GDB_BINARY": "challenge/bench_local_nonpie/chall",
    "DIRGE_FAKE_GDB_CRASH_RIP": "0x401170"
  },
  "expect": {
    "run_rc": 0,
    "final_exit_code": 0,
    "acceptance_passed": true,
    "required_success_stages": ["recon", "gdb_evidence"],
    "stage_sequence": ["recon", "gdb_evidence"],
    "forbid_stage_cache_hits": ["recon", "gdb_evidence"],
    "state_paths": {
      "session.session_id": "{{SESSION_ID}}",
      "latest_bases.pie_base": "0x400000",
      "dynamic_evidence.evidence[0].source": "gdb_direct_probe",
      "dynamic_evidence.evidence[0].gdb.rip": "0x401170",
      "dynamic_evidence.evidence[0].gdb.pc_offset": "0x1170",
      "dynamic_evidence.evidence[0].gdb.control_rip": true,
      "dynamic_evidence.evidence[0].gdb.offset_to_rip": 88,
      "dynamic_evidence.inputs[0].stdin_source": "file:./cyclic88.txt",
      "dynamic_evidence.inputs[0].kind": "seeded_file",
      "dynamic_evidence.inputs[0].cyclic_compatible": true,
      "capabilities.control_rip": true,
      "capabilities.offset_to_rip": 88
    },
    "notes_contains": [
      "direct gdb probe: on",
      "codex missing: prefer portable local recon + direct gdb probe fallback"
    ]
  },
  "notes": "从 challenge 工作目录启动 direct probe，并把 stdin payload 文件写成 cwd-relative ./cyclic88.txt，锁住 host-side shell/wrapper 最常见的 dotfile 相对路径形态不会因为 repo/cwd 漂移而把 direct gdb 文件重放跑偏。"
}
