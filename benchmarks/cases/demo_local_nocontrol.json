{
  "enabled": true,
  "challenge_dir": "challenge/bench_local_nocontrol",
  "binary": "chall",
  "max_loops": 1,
  "allow_codex_missing": true,
  "ensure_binary_executable": true,
  "clear_cached_artifacts": true,
  "required_commands": [
    "gdb"
  ],
  "env": {
    "DIRGE_PREFER_LOCAL_GDB_ON_CODEX_MISSING": "1",
    "DIRGE_LOCAL_GDB_STDIN_TEXT": "TRIGGER\n"
  },
  "expect": {
    "run_rc": 0,
    "final_exit_code": 0,
    "required_success_stages": [
      "recon",
      "gdb_evidence"
    ],
    "stage_sequence": [
      "recon",
      "gdb_evidence"
    ],
    "forbid_stage_cache_hits": [
      "recon",
      "gdb_evidence"
    ],
    "metrics_min": {
      "runs_total": 1
    },
    "state_paths": {
      "session.status": "finished",
      "recon.mode": "local_recon_fallback",
      "gdb.mode": "local_gdb_fallback",
      "gdb.signal": "SIGSEGV",
      "capabilities.has_crash": true,
      "capabilities.control_rip": false,
      "capabilities.rip_control": "no"
    },
    "notes_contains": [
      "codex missing: prefer portable local recon + local gdb evidence fallback"
    ],
    "notes_absent": [
      "OpenClaw-specific fallback"
    ]
  },
  "notes": "本地 no-Codex benchmark，验证 portable local gdb fallback 不会把普通 null-deref 崩溃误判成 control_rip=true"
}
