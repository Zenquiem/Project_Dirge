    "DIRGE_GDB_DIRECT_STDIN_HEX": "614130614131614132614133614134614135614136614137614138614139614230614231614232614233614234614235614236614237614238614239614330614331614332614333614334614335614336614337614338614339614430614431614432614433614434614435614436614437614438614439",
    "DIRGE_FAKE_GDB_BINARY": "challenge/bench_local_nonpie/chall",
    "DIRGE_FAKE_GDB_CRASH_RIP": "0x401170"
  },
  "expect": {
    "run_rc": 0,
    "final_exit_code": 0,
    "acceptance_passed": true,
